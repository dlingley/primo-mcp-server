# Primo MCP Server Configuration
# All values have Purdue defaults -- only override if connecting to a different institution.

# PRIMO_BASE_URL=https://purdue.primo.exlibrisgroup.com/primaws/rest/pub
# PRIMO_DISCOVERY_BASE_URL=https://purdue.primo.exlibrisgroup.com/discovery
# PRIMO_VID=01PURDUE_PUWL:PURDUE
# Institution code for the anonymous guest JWT used by direct record
# lookup. Defaults to the part of PRIMO_VID before the colon.
# PRIMO_INSTITUTION_CODE=01PURDUE_PUWL
# PRIMO_INSTITUTION_NAME=Purdue University
# PRIMO_TAB_EVERYTHING=Everything
# PRIMO_TAB_CATALOGUE=Catalogue
# PRIMO_TAB_BOOKS_VIDEOS=booksandvideos
# PRIMO_SCOPE_COMBINED=MyInst_and_CI
# PRIMO_SCOPE_LOCAL=MyInstitution
# PRIMO_SCOPE_BOOKS_VIDEOS=BooksVideos
# PRIMO_REQUEST_TIMEOUT=30.0
# Retries for transient Primo failures (timeout, connection error, HTTP
# 429/5xx): extra attempts after the first, and the backoff cap in seconds
# (a numeric Retry-After from the server is honoured up to the cap).
# PRIMO_REQUEST_RETRY_ATTEMPTS=1
# PRIMO_REQUEST_RETRY_MAX_DELAY=5.0
# PRIMO_MAX_RESULTS_PER_REQUEST=50
# PRIMO_DEFAULT_RESULTS=10
# PRIMO_LANGUAGE=en
# Include CDI records without full text access in search results.
# Defaults to false so searches prefer accessible records.
# PRIMO_INCLUDE_UNAVAILABLE=false
