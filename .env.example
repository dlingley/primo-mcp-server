# Primo MCP Server Configuration
# All values have Purdue defaults -- only override if connecting to a different institution.

# PRIMO_BASE_URL=https://purdue.primo.exlibrisgroup.com/primaws/rest/pub
# PRIMO_DISCOVERY_BASE_URL=https://purdue.primo.exlibrisgroup.com/discovery
# PRIMO_VID=01PURDUE_PUWL:PURDUE
# Institution code for the anonymous guest JWT used by direct record
# lookup. Defaults to the part of PRIMO_VID before the colon.
# PRIMO_INSTITUTION_CODE=01PURDUE_PUWL
# PRIMO_INSTITUTION_NAME=Purdue University
# PRIMO_TAB_EVERYTHING=Everything
# PRIMO_TAB_CATALOGUE=Catalogue
# PRIMO_TAB_BOOKS_VIDEOS=booksandvideos
# PRIMO_SCOPE_COMBINED=MyInst_and_CI
# PRIMO_SCOPE_LOCAL=MyInstitution
# PRIMO_SCOPE_BOOKS_VIDEOS=BooksVideos
# PRIMO_REQUEST_TIMEOUT=30.0
# Retries for transient Primo failures (timeout, connection error, HTTP
# 429/5xx): extra attempts after the first, and the backoff cap in seconds
# (a numeric Retry-After from the server is honoured up to the cap).
# PRIMO_REQUEST_RETRY_ATTEMPTS=1
# PRIMO_REQUEST_RETRY_MAX_DELAY=5.0
# PRIMO_MAX_RESULTS_PER_REQUEST=50
# PRIMO_DEFAULT_RESULTS=10
# PRIMO_LANGUAGE=en
# Include CDI records without full text access in search results.
# Defaults to false so searches prefer accessible records.
# PRIMO_INCLUDE_UNAVAILABLE=false

# Optional external JSON directory for librarian recommendations.
# Expected shape: {"librarians": [{"id": "...", "name": "...", "best_for": ["..."]}]}
# PRIMO_LIBRARIANS_FILE=data/purdue-librarians.json
# PRIMO_INLINE_LIBRARIAN_RECOMMENDATIONS=true
# PRIMO_LIBRARIAN_MIN_SCORE=5.0

# Optional semantic (embedding) fallback for librarian recommendations.
# Consulted when keyword matching finds no librarian, or when its best match
# scores below the second-guess threshold -- so the embedding cost is paid
# only when keywords are weak or absent. Uses Google's gemini-embedding-001
# (free tier: get a key at https://aistudio.google.com/apikey). Semantic
# results are clearly labelled and report their cosine similarity.
# Disabled by default.
# PRIMO_LIBRARIAN_SEMANTIC_FALLBACK=true
# PRIMO_EMBEDDING_API_KEY=your-gemini-api-key
# PRIMO_EMBEDDING_MODEL=gemini-embedding-001
# PRIMO_EMBEDDING_API_URL=https://generativelanguage.googleapis.com/v1beta
# Quota-free alternative: serve embeddings locally from any OpenAI-compatible
# endpoint (Ollama, LM Studio, llama.cpp). Defaults target Ollama running
# EmbeddingGemma (`ollama pull embeddinggemma`); no API key needed. The
# prefixes stand in for Gemini's taskType -- for nomic-embed-text use
# "search_query: " / "search_document: ". Re-run the calibration CLI when
# switching models: the cosine floor was tuned for gemini-embedding-001.
# PRIMO_EMBEDDING_PROVIDER=local
# PRIMO_EMBEDDING_LOCAL_URL=http://localhost:11434/v1
# PRIMO_EMBEDDING_LOCAL_MODEL=embeddinggemma
# Optional Bearer token for local runtimes that check one. Separate from
# PRIMO_EMBEDDING_API_KEY, which is Gemini-only and never sent locally.
# PRIMO_EMBEDDING_LOCAL_API_KEY=
# Quote the prefixes: the trailing space is part of the prompt and an
# unquoted .env value would lose it.
# PRIMO_EMBEDDING_LOCAL_QUERY_PREFIX="task: search result | query: "
# PRIMO_EMBEDDING_LOCAL_DOCUMENT_PREFIX="title: none | text: "
# Acceptance is self-calibrating: besides the absolute cosine floor below,
# the top match must exceed the mean similarity across all profiles by the
# margin (applied once the directory has MARGIN_MIN_PROFILES profiles).
# Smaller directories require the top match to lead the runner-up by
# MIN_TOP_GAP instead; a single-profile directory uses the floor alone.
# Calibrate for your own directory with:
#   python -m purduelibrary_mcp_server.calibrate_embeddings "test query" ...
# PRIMO_LIBRARIAN_SEMANTIC_MIN_SIMILARITY=0.60
# PRIMO_LIBRARIAN_SEMANTIC_MARGIN=0.08
# PRIMO_LIBRARIAN_SEMANTIC_MARGIN_MIN_PROFILES=4
# PRIMO_LIBRARIAN_SEMANTIC_MIN_TOP_GAP=0.05
# Skip the semantic fallback (and its embedding call) when the query has
# fewer topical words than this; short/vague queries embed unreliably.
# Set to 1 to disable the gate.
# PRIMO_LIBRARIAN_SEMANTIC_MIN_QUERY_TOKENS=2
# Keyword matches scoring below this are second-guessed by the semantic
# path (0 restores the old strict miss-only cascade).
# PRIMO_LIBRARIAN_SEMANTIC_SECOND_GUESS_SCORE=12.0
# Optional Matryoshka truncation (e.g. 768) to cut cache size and latency;
# changing it invalidates cached profile embeddings.
# PRIMO_EMBEDDING_DIMENSIONS=768
# Where profile embeddings are cached (defaults next to PRIMO_LIBRARIANS_FILE).
# PRIMO_EMBEDDING_CACHE_FILE=C:\path\to\librarian-profile-embeddings.json
# PRIMO_EMBEDDING_TIMEOUT=10.0
# Tighter embedding budget for inline primo_search recommendations, so a
# slow embedding call cannot delay ordinary searches by the full timeout.
# PRIMO_EMBEDDING_INLINE_TIMEOUT=2.5
